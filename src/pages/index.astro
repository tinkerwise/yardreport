---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Yard Report">
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <a class="logo" href="https://www.briancsmith.org/yardreport">
        <img class="logo-img" src={`${import.meta.env.BASE_URL}logo.png`} alt="Yard Report logo" height="36" />
        <span>Yard <strong>Report</strong></span>
      </a>
      <div class="header-right">
        <span class="cache-label" id="cacheLabel"></span>
        <button class="btn-refresh" id="refreshBtn" aria-label="Refresh news">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
            <path d="M21 3v5h-5"/>
            <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
            <path d="M8 16H3v5"/>
          </svg>
          Refresh
        </button>
      </div>
    </div>
  </header>

  <!-- Scores Bar -->
  <div class="scores-bar">
    <div class="scores-track" id="scoresTrack">
      <span class="scores-msg">Loading scores…</span>
    </div>
  </div>

  <!-- Page Layout -->
  <div class="page-layout">

    <!-- Sidebar -->
    <aside class="sidebar">
      <!-- Search -->
      <div class="search-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input class="search-input" id="searchInput" type="search" placeholder="Search all articles…" autocomplete="off" />
      </div>

      <!-- Category Filter -->
      <div class="filter-section">
        <h3 class="section-label">Category</h3>
        <div class="pill-group" id="categoryFilters">
          <button class="pill active" data-category="all">All</button>
          <button class="pill" data-category="orioles">🟠 Orioles</button>
          <button class="pill" data-category="mlb">⚾ MLB</button>
        </div>
      </div>

      <!-- Source Filter -->
      <div class="filter-section">
        <h3 class="section-label">Sources</h3>
        <div class="pill-group" id="sourceFilters">
          <button class="pill active" data-source="all">All</button>
        </div>
      </div>

      <!-- Standings -->
      <div class="standings-section">
        <h3 class="section-label">Standings</h3>
        <div class="div-tabs" id="divTabs"></div>
        <div id="standingsWrap">
          <span class="sidebar-msg">Loading…</span>
        </div>
      </div>
    </aside>

    <!-- Feed -->
    <main class="feed-area">
      <div class="feed-toolbar">
        <span class="result-count" id="resultCount"></span>
        <div class="toolbar-controls">
          <div class="view-toggle" id="viewToggle">
            <button class="view-btn active" data-view="grid" title="Grid view">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
            </button>
            <button class="view-btn" data-view="list" title="List view">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="4" height="4" rx="1"/><rect x="7" y="2" width="8" height="2" rx="0.5"/><rect x="1" y="6" width="4" height="4" rx="1"/><rect x="7" y="7" width="8" height="2" rx="0.5"/><rect x="1" y="11" width="4" height="4" rx="1"/><rect x="7" y="12" width="8" height="2" rx="0.5"/></svg>
            </button>
            <button class="view-btn" data-view="compact" title="Compact view">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="2" width="14" height="2" rx="0.5"/><rect x="1" y="7" width="14" height="2" rx="0.5"/><rect x="1" y="12" width="14" height="2" rx="0.5"/></svg>
            </button>
          </div>
          <select class="sort-select" id="sortSelect">
            <option value="date">Newest first</option>
            <option value="dateGroup">By date</option>
            <option value="source">By source</option>
          </select>
        </div>
      </div>
      <div class="article-list" id="articleList">
        <div class="feed-msg">Loading news…</div>
      </div>
    </main>

  </div>

  <!-- Reader Modal -->
  <div class="reader-overlay hidden" id="readerOverlay">
    <div class="reader-modal">
      <div class="reader-bar">
        <div class="reader-meta">
          <span class="reader-source-badge" id="readerBadge"></span>
          <span class="reader-date" id="readerDate"></span>
        </div>
        <div class="reader-actions">
          <a class="btn-original-reader" id="readerLink" href="#" target="_blank" rel="noopener noreferrer">
            Open original ↗
          </a>
          <button class="btn-close-reader" id="readerClose" aria-label="Close reader">✕</button>
        </div>
      </div>
      <h1 class="reader-title" id="readerTitle"></h1>
      <div class="reader-body">
        <iframe
          class="reader-frame hidden"
          id="readerFrame"
          sandbox="allow-same-origin allow-popups allow-forms"
          title="Article content"
        ></iframe>
        <div class="reader-fallback" id="readerFallback">
          <p class="reader-excerpt" id="readerExcerpt"></p>
          <a class="btn-read-full" id="readerFullLink" href="#" target="_blank" rel="noopener noreferrer">
            Read full article ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import '../scripts/app.js';
</script>
