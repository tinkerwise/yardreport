---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Yard Report">
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <a class="logo" href="https://www.briancsmith.org/yardreport">
        <img class="logo-img" src={`${import.meta.env.BASE_URL}logo.png`} alt="Yard Report logo" height="36" />
        <span>Yard <strong>Report</strong></span>
      </a>
      <div class="header-right">
        <span class="cache-label" id="cacheLabel"></span>
        <button class="btn-refresh" id="refreshBtn" aria-label="Refresh news">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
            <path d="M21 3v5h-5"/>
            <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
            <path d="M8 16H3v5"/>
          </svg>
          Refresh
        </button>
        <button class="btn-settings" id="settingsBtn" aria-label="Settings">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Scores Bar -->
  <div class="scores-bar">
    <div class="scores-track" id="scoresTrack">
      <span class="scores-msg">Loading scores…</span>
    </div>
  </div>

  <!-- Page Layout -->
  <div class="page-layout">

    <!-- Left Sidebar -->
    <aside class="sidebar sidebar-left">
      <!-- Search -->
      <div class="search-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input class="search-input" id="searchInput" type="search" placeholder="Search all articles…" autocomplete="off" />
      </div>

      <!-- Video -->
      <div class="sidebar-section collapsible" data-section="video">
        <h3 class="section-label section-toggle" data-target="video">
          <svg class="section-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          Video
          <svg class="section-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </h3>
        <div class="section-body" id="videoWrap">
          <span class="sidebar-msg">Loading…</span>
        </div>
      </div>

      <!-- On Deck + Schedule -->
      <div class="sidebar-section collapsible" data-section="ondeck">
        <h3 class="section-label section-toggle" data-target="ondeck">
          <svg class="section-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          On Deck
          <svg class="section-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </h3>
        <div class="section-body" id="onDeckWrap">
          <span class="sidebar-msg">Loading…</span>
        </div>
      </div>

      <!-- Standings -->
      <div class="sidebar-section collapsible" data-section="standings">
        <h3 class="section-label section-toggle" data-target="standings">
          <svg class="section-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 21h8m-4-4v4M3 11h18M5 11V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v6"/><path d="m12 11-1.5 4h3L12 11z"/></svg>
          Standings
          <svg class="section-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </h3>
        <div class="section-body">
          <div class="div-tabs" id="divTabs"></div>
          <div id="standingsWrap">
            <span class="sidebar-msg">Loading…</span>
          </div>
        </div>
      </div>
    </aside>

    <!-- Feed -->
    <main class="feed-area">
      <div class="feed-toolbar">
        <div class="toolbar-left">
          <div class="pill-group" id="categoryFilters">
            <button class="pill active" data-category="all">All</button>
            <button class="pill" data-category="orioles">🟠 Orioles</button>
            <button class="pill" data-category="mlb">⚾ MLB</button>
            <button class="pill" data-category="milb">🔻 MiLB</button>
          </div>
        </div>
        <div class="toolbar-controls">
          <div class="source-filter-wrap">
            <button class="btn-source-filter" id="sourceFilterBtn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
              Sources
            </button>
            <div class="source-popover hidden" id="sourcePopover">
              <div class="pill-group" id="sourceFilters">
                <button class="pill active" data-source="all">All</button>
              </div>
            </div>
          </div>
          <select class="sort-select" id="sortSelect">
            <option value="date">Newest first</option>
            <option value="dateGroup">By date</option>
            <option value="source">By source</option>
          </select>
          <select class="sort-select" id="dateRangeSelect">
            <option value="3" selected>3 days</option>
            <option value="7">7 days</option>
            <option value="14">14 days</option>
            <option value="30">30 days</option>
          </select>
          <div class="view-toggle" id="viewToggle">
            <button class="view-btn active" data-view="grid" title="Grid view">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
            </button>
            <button class="view-btn" data-view="list" title="List view">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="4" height="4" rx="1"/><rect x="7" y="2" width="8" height="2" rx="0.5"/><rect x="1" y="6" width="4" height="4" rx="1"/><rect x="7" y="7" width="8" height="2" rx="0.5"/><rect x="1" y="11" width="4" height="4" rx="1"/><rect x="7" y="12" width="8" height="2" rx="0.5"/></svg>
            </button>
            <button class="view-btn" data-view="compact" title="Compact view">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="2" width="14" height="2" rx="0.5"/><rect x="1" y="7" width="14" height="2" rx="0.5"/><rect x="1" y="12" width="14" height="2" rx="0.5"/></svg>
            </button>
          </div>
        </div>
      </div>
      <div class="article-list" id="articleList">
        <div class="feed-msg">Loading news…</div>
      </div>
    </main>

    <!-- Right Sidebar -->
    <aside class="sidebar sidebar-right">
      <!-- Yard Leaders -->
      <div class="sidebar-section collapsible" data-section="leaders">
        <h3 class="section-label section-toggle" data-target="leaders">
          <svg class="section-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Yard Leaders
          <svg class="section-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </h3>
        <div class="section-body" id="leadersWrap">
          <span class="sidebar-msg">Loading…</span>
        </div>
      </div>

      <!-- Roster -->
      <div class="sidebar-section collapsible collapsed" data-section="roster">
        <h3 class="section-label section-toggle" data-target="roster">
          <svg class="section-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Roster
          <svg class="section-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </h3>
        <div class="section-body" id="rosterWrap">
          <span class="sidebar-msg">Loading…</span>
        </div>
      </div>

      <!-- Injury Report -->
      <div class="sidebar-section collapsible" data-section="il">
        <h3 class="section-label section-toggle" data-target="il">
          <svg class="section-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-3-3v6"/><circle cx="12" cy="12" r="10"/></svg>
          Injury Report
          <svg class="section-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </h3>
        <div class="section-body" id="ilWrap">
          <span class="sidebar-msg">Loading…</span>
        </div>
      </div>

      <!-- Transactions -->
      <div class="sidebar-section collapsible" data-section="transactions">
        <h3 class="section-label section-toggle" data-target="transactions">
          <svg class="section-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/></svg>
          Transactions
          <svg class="section-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </h3>
        <div class="section-body" id="transactionsWrap">
          <span class="sidebar-msg">Loading…</span>
        </div>
      </div>

    </aside>

  </div>

  <!-- Settings Overlay -->
  <div class="settings-overlay hidden" id="settingsOverlay">
    <div class="settings-panel">
      <div class="settings-header">
        <h2 class="settings-title">Settings</h2>
        <button class="btn-close-settings" id="settingsClose" aria-label="Close settings">✕</button>
      </div>
      <div class="settings-body">
        <div class="settings-group">
          <label class="settings-label">Theme</label>
          <div class="theme-toggle" id="themeToggle">
            <button class="theme-btn" data-theme="light">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
              Light
            </button>
            <button class="theme-btn" data-theme="dark">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              Dark
            </button>
            <button class="theme-btn" data-theme="system">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              System
            </button>
          </div>
        </div>
        <div class="settings-group">
          <label class="settings-label">Default View</label>
          <div class="theme-toggle" id="defaultViewToggle">
            <button class="theme-btn" data-defview="grid">Grid</button>
            <button class="theme-btn" data-defview="list">List</button>
            <button class="theme-btn" data-defview="compact">Compact</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reader Modal -->
  <div class="reader-overlay hidden" id="readerOverlay">
    <div class="reader-modal">
      <div class="reader-bar">
        <div class="reader-meta">
          <span class="reader-source-badge" id="readerBadge"></span>
          <span class="reader-date" id="readerDate"></span>
        </div>
        <div class="reader-actions">
          <a class="btn-original-reader" id="readerLink" href="#" target="_blank" rel="noopener noreferrer">
            Open original ↗
          </a>
          <button class="btn-close-reader" id="readerClose" aria-label="Close reader">✕</button>
        </div>
      </div>
      <h1 class="reader-title" id="readerTitle"></h1>
      <div class="reader-body">
        <iframe
          class="reader-frame hidden"
          id="readerFrame"
          sandbox="allow-same-origin allow-popups allow-forms"
          title="Article content"
        ></iframe>
        <div class="reader-fallback" id="readerFallback">
          <p class="reader-excerpt" id="readerExcerpt"></p>
          <a class="btn-read-full" id="readerFullLink" href="#" target="_blank" rel="noopener noreferrer">
            Read full article ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import '../scripts/app.js';
</script>
