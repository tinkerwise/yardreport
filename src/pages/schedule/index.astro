---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Schedule | Yard Report">
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <a class="logo" href={base}>
        <img class="logo-img" src={`${base}logo.png`} alt="Yard Report logo" height="36" />
        <span class="logo-wordmark" aria-label="Yard Report">
          <span class="logo-word">Yard</span>
          <strong class="logo-word logo-word-accent">Report</strong>
        </span>
      </a>
      <nav class="header-right header-breadcrumb" aria-label="Breadcrumb">
        <a class="breadcrumb-link" href={base}>← Yard Report</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span class="breadcrumb-current">Schedule</span>
      </nav>
    </div>
  </header>

  <main class="schedule-page">
    <div class="schedule-container">

      <!-- Toolbar -->
      <div class="schedule-toolbar">
        <div class="schedule-nav-group">
          <button class="sch-nav-btn" id="prevBtn" aria-label="Previous">‹</button>
          <h2 class="sch-title" id="schTitle">Loading…</h2>
          <button class="sch-nav-btn" id="nextBtn" aria-label="Next">›</button>
          <button class="sch-today-btn" id="todayBtn">Today</button>
        </div>
        <div class="sch-view-group" role="group" aria-label="Calendar view">
          <button class="sch-view-btn active" data-view="month">Month</button>
          <button class="sch-view-btn" data-view="week">Week</button>
        </div>
      </div>

      <!-- Legend -->
      <div class="sch-legend">
        <span class="sch-legend-item legend--home">🏟 Home</span>
        <span class="sch-legend-item legend--away">✈ Away</span>
        <span class="sch-legend-item legend--live">● Live</span>
        <span class="sch-legend-item legend--preview">W 5–3 · L 2–4</span>
      </div>

      <!-- Calendar -->
      <div id="scheduleGrid">
        <div class="sch-loading">Loading schedule…</div>
      </div>

    </div>
  </main>
</Layout>

<script>
  import '../../scripts/schedule.js';
</script>
